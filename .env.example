ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
# Zoom Server-to-Server OAuth credentials
# Create an app at https://marketplace.zoom.us/ → Develop → Build App → Server-to-Server OAuth
# Required scopes: room:read:admin, dashboard:read:admin, meeting:read:admin
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
FLEET_API_URL=https://your-fleet-instance.example.com
FLEET_API_TOKEN=

TEQTIVITY_API_URL=https://your-teqtivity-instance.example.com
TEQTIVITY_API_KEY=

# Jira (used by jira_device_comment.py)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here

# Anthropic (used by jira_device_comment.py to extract Zoom room name from description)
ANTHROPIC_API_KEY=your-api-key-here
